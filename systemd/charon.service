# vim: ft=systemd
[Unit]
Description=Charon is a package manager
DefaultDependencies=yes
Requires=buckle.service
After=buckle.service

[Service]
Type=exec
ExecStartPre=-/usr/bin/podman rm -f charon
ExecStart=/usr/bin/podman run --pull=always -it --privileged --name charon --security-opt label=disable --net bridge --pid host --volumes-from buckle -v /etc/systemd:/etc/systemd:shared -v /town-os:/town-os:shared quay.io/town-os/charon:latest
Restart=always

[Install]
WantedBy=default.target

