#!/bin/bash

build() {
    add_module btrfs
    add_binary /usr/bin/ttyforce
    add_binary setsid
    add_binary wpa_supplicant
    add_binary wpa_cli
    add_binary dhcpcd
    # dhcpcd's resolvconf hook + runner, so dhcpcd writes /etc/resolv.conf (and
    # the /run/dhcpcd/resolv.conf/<iface>.* fragments) from the DHCP lease itself.
    # Without these, dhcpcd in the initrd never touches resolv.conf, and the
    # statically seeded public DNS (8.8.8.8/1.1.1.1 — blocked on NAT/captive
    # networks) is what curl sees when ttyforce fetches GitHub SSH keys. The
    # runner is dhcpcd's compiled-in default --script, so its mere presence
    # activates it (no flag change). Both files ship with the dhcpcd package
    # (make/base-packages.txt) and exist in the pacstrapped rootfs at build time.
    add_file /usr/lib/dhcpcd/dhcpcd-run-hooks
    add_file /usr/lib/dhcpcd/dhcpcd-hooks/20-resolv.conf
    add_binary ip
    add_binary iw
    add_binary iwlist
    add_binary rfkill
    add_binary ping
    add_binary pkill
    add_binary agetty
    add_binary parted
    add_binary partprobe
    add_binary udevadm
    add_binary mkfs.btrfs
    add_binary wipefs
    add_binary umount
    add_binary mountpoint
    add_binary mount
    add_binary mkdir
    add_binary btrfs
    add_binary tr
    add_binary curl
    add_file /etc/ssl/certs/ca-certificates.crt
    add_runscript
}

help() {
    cat <<HELPEOF
Runs ttyforce in the initrd to detect and provision hardware
before the root filesystem is mounted.
HELPEOF
}
